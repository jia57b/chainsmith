# Cronos Multi-Validator Localnet Environment Variables

# Local image (built automatically by init-multinode.sh if missing)
CRONOS_IMAGE=chainsmith/cronosd:local

# Upstream source tag used when building image
CRONOS_TAG=v1.7.0

# CometBFT persistent peers (auto-populated by init-multinode.sh)
PERSISTENT_PEERS=""

# Logging
LOG_LEVEL=info
