{
    "description": "Load and Stress Test Configuration",
    "usage": "Copy to load-stress.config.json and adjust settings for your environment",
    "environments": {
        "local": {
            "createNewWallet": true,
            "fundingAmount": "0.1",
            "testTransactionAmount": "0.001",
            "fundingBatchSize": 50,
            "fundingBatchDelayMs": 200
        },
        "avalanche-local": {
            "createNewWallet": true,
            "fundingAmount": "0.05",
            "testTransactionAmount": "0.001",
            "fundingBatchSize": 10,
            "fundingBatchDelayMs": 300,
            "testOverrides": {
                "stress01": {
                    "sourceWalletCount": 10,
                    "destWalletCount": 1,
                    "timeout": 300000
                },
                "stress02": {
                    "sourceWalletCount": 12,
                    "destWalletCount": 1,
                    "batchSize": [2, 4, 6],
                    "timeout": 300000
                },
                "stress03": {
                    "sourceWalletCount": 10,
                    "destWalletCount": 1,
                    "gasPricesGwei": [30, 40, 50],
                    "timeout": 300000
                },
                "load01": {
                    "sourceWalletCount": 10,
                    "destWalletCount": 1,
                    "testDuration": 0.25,
                    "batchSize": 2,
                    "batchIntervalMs": 1000,
                    "timeout": 300000
                }
            }
        },
        "testnet": {
            "createNewWallet": false,
            "fundingAmount": "0.1",
            "testTransactionAmount": "0.001",
            "fundingBatchSize": 50,
            "fundingBatchDelayMs": 200,
            "walletEnvPrefix": "LOAD_WALLET_PK",
            "walletCount": 3
        },
        "qa": {
            "createNewWallet": false,
            "fundingAmount": "0.05",
            "testTransactionAmount": "0.0001",
            "fundingBatchSize": 50,
            "fundingBatchDelayMs": 200,
            "walletEnvPrefix": "LOAD_WALLET_PK",
            "walletCount": 5
        }
    },
    "tests": {
        "stress01": {
            "name": "Concurrent Transaction Test",
            "description": "Multiple source wallets sending transactions concurrently",
            "sourceWalletCount": 50,
            "destWalletCount": 1,
            "timeout": 900000
        },
        "stress02": {
            "name": "Batch Transaction Test",
            "description": "Test batch transactions with different batch sizes",
            "sourceWalletCount": 50,
            "destWalletCount": 1,
            "batchSize": [2, 5, 10],
            "timeout": 600000
        },
        "stress03": {
            "name": "Gas Price Optimization Test",
            "description": "Test transactions with different gas prices",
            "sourceWalletCount": 50,
            "destWalletCount": 1,
            "gasPricesGwei": [20, 30, 40, 50],
            "timeout": 600000
        },
        "load01": {
            "name": "Sustained Load Test",
            "description": "Maintain consistent TPS over time",
            "sourceWalletCount": 50,
            "destWalletCount": 1,
            "testDuration": 1,
            "batchSize": 2,
            "batchIntervalMs": 500,
            "timeout": 600000
        }
    }
}
